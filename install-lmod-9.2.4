#!/bin/bash

# Check that SCRIPT_ROOT is set before continuing.
[ -z "$SCRIPT_ROOT" ] && echo "
You must export the variable SCRIPT_ROOT and set it to be the root of
the build script repository directory structure to run build scripts
" && exit 9

build_dir=/tmp/bennetsw/build
if [ ! -d $build_dir ] ; then
    mkdir -p $build_dir
fi
cd $build_dir || exit 1
lmod_ver=9.2.4

if [ -d lmod-$lmod_ver ] ; then
    rm -rf lmod-$lmod_ver
fi

# Get source from GitHub
git clone https://github.com/TACC/Lmod.git lmod-$lmod_ver

# Check out the right tag to a branch
cd lmod-$lmod_ver || exit 1
git checkout tags/$lmod_ver -b $lmod_ver

# Check the branch is OK, just 'cause
git branch

# Set the spider cache directory
spider_dir=/sw/lmod/cache

if [ ! -d "$spider_dir" ] ; then
    mkdir -p "$spider_dir"
fi

# Configure with the right cache information
./configure --prefix=/sw \
    --with-spiderCacheDir=$spider_dir \
    --with-updateSystemFn=$spider_dir/cacheTS.txt

# Make the preinstall version
make pre-install

# Change to the init directory for the new version
cd /sw/lmod/$lmod_ver/init || exit 1

# Create the init/.modulespath file with the default paths in it
# As of 23 August, 2018, only arcts trees are included.

cat << __EOF__ > /sw/lmod/$lmod_ver/init/.modulespath
/sw/lmod/lmod/modulefiles/Core
/sw/modules/Core
__EOF__

printf "\n\n========================= .modulespath =========================\n"
cat /sw/lmod/$lmod_ver/init/.modulespath
printf "================================================================\n"


# This is the directory that contains SitePackage.lua and the zz* files

# Check the line numbers on this.  This should put it right after
# 45   export BASH_ENV=/sw/lmod/8.5.28/init/bash
sed -i.orig '46i\    #### Begin ARC change\n\    export LMOD_PACKAGE_PATH=\/sw\/lmod\n\    #### End ARC change/' profile

# Check the line numbers on this.  This should put it right after
# 49     setenv BASH_ENV      "/sw/lmod/8.5.28/init/bash"
sed -i.orig '50i\    #### Begin ARC change\n\    setenv LMOD_PACKAGE_PATH    "/sw/lmod"\n\    #### End ARC change/' cshrc

# Put the version number in the init files; using lmod/lmod may
#   cause difficulties trying to test a new version because it
#   refers back to the old version to which lmod/lmod still points.
#   That led to spurious bug report when going from 6.x to 7.x.
sed -i "s/lmod\/lmod/lmod\/$lmod_ver/g" profile
sed -i "s/lmod\/lmod/lmod\/$lmod_ver/g" cshrc

# Check the differences
diff profile.orig profile
diff cshrc.orig cshrc

# Replace lmod/lmod in libexec/update_lmod_system_cache_files, too,
#   so that proper testing of the spider caching will work.
cd /sw/lmod/$lmod_ver/libexec || exit 1
sed -i.orig "s/lmod\/lmod/lmod\/$lmod_ver/g" update_lmod_system_cache_files
diff update_lmod_system_cache_files.orig update_lmod_system_cache_files

###
### Be vewwy, vewwy careful with $ inside here docs!
###    \$ is super-needed if you mean for the $ to make it into the doc
### You have been warned, wabbit
###
# Create the SitePackage.lua file
cat << __EOF__ > /sw/lmod/SitePackage.lua
--------------------------------------------------------------------------
-- This is the SitePackage module for ARC

require("strict")
require("lmod_system_execute")

-- load_hook(): Here we record the modules loaded.

local hook   = require("Hook")
local uname  = require("posix").uname
local dbg    = require("Dbg"):dbg()

local s_msgA = {}

function load_hook(t)
    -- the arg t is a table:
    --     t.modFullName:  the module full name: (i.e: gcc/4.7.2)
    --     t.fn:           The file name: (i.e /apps/modulefiles/Core/gcc/4.7.2.lua)

    if (mode() ~= "load") then return end
    local user        = os.getenv("USER")
    local host        = uname("%n")
    local currentTime = epoch()
    local msg         = string.format("user=%s module=%s path=%s host=%s time=%f",
                                      user, t.modFullName, t.fn, host, currentTime)
    local a           = s_msgA
    a[#a+1]           = msg
end


hook.register("load",load_hook)

function report_loads()

    local sys         = os.getenv("LMOD_sys") or "Linux"
    if (sys == "Linux") then
        local a = s_msgA
        for i = 1,#a do
            local msg = a[i]
            lmod_system_execute("logger -t ModuleUsageTracking -p local0.info " .. msg)
        end
    end

end


ExitHookA.register(report_loads)

local mapT = {
    grouped = {
        ['/Core.*']                 = "Core applications including compilers",
        ['/Compilers/gcc%-8_3_1']    = "Applications compiled with GCC 4.8.5",
    },
}

function avail_hook(t)

    local availStyle = masterTbl().availStyle
    dbg.print{"avail hook called: availStyle: ",availStyle,"\n"}
    local styleT = mapT[availStyle]
    if (not availStyle or availStyle == "system" or styleT == nil) then
        return
    end

    for k,v in pairs(t) do
        for pat,label in pairs(styleT) do
            if (k:find(pat)) then
                t[k] = label
                break
            end
        end
    end
end

hook.register("avail",avail_hook)

__EOF__


###
### Be vewwy, vewwy caeful with $ inside here docs!
###    \$ is super-needed if you mean for it to make it into the doc
###
cat << __EOF__ > /sw/lmod/z11StdEnv.sh
#!/bin/bash

#  Set the folder where SitePackage.lua lives
export LMOD_PACKAGE_PATH=/sw/lmod

#  Export the LMOD available display style variable

export LMOD_AVAIL_STYLE="grouped"

#  Initialize Lmod
source /sw/lmod/lmod/init/profile

# Check whether there is a default save set, and if there is, restore
# it.  This is in lieu of system default modules.
if [ -e \${HOME}/.lmod.d/default ] ; then
    # User specific aliases and functions
    if [ -z "\$ARCTS_LMOD_DEFAULT_SET" ]; then
        export ARCTS_LMOD_DEFAULT_SET=1
        # Place any module commands here
        module restore
    fi
fi
export PATH=/sw/arc/usertools/bin:\${PATH}

__EOF__

# Go back and make install
cd $build_dir/lmod-$lmod_ver || exit 1
make install

# Create the first Lmod spider cache
#
# NOTE:  This doesn't work on first installation until something sets
# BASE_MODULEPATH

# shellcheck disable=SC1091
source /sw/lmod/z11StdEnv.sh
echo "MODULEPATH is $MODULEPATH"

/sw/lmod/$lmod_ver/libexec/update_lmod_system_cache_files \
    -d /sw/lmod/cache/$lmod_ver \
    -t /sw/lmod/cache/$lmod_ver/cacheTS.txt \
    "$MODULEPATH"

# Check the existence and modify time of the spider cache files
ls -l /sw/lmod/cache/$lmod_ver

